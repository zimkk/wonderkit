# ============================================================
# AI Kit — environment variables
# Copy to .env and fill in. Every var: what it is, where to get
# it, and whether it is required.
# ============================================================

# --- Database (REQUIRED) ------------------------------------
# Postgres 16 with pgvector. Local dev: `docker compose -f docker-compose.dev.yml up -d`
# Vercel path: Neon connection string (enable pgvector extension).
DATABASE_URL="postgresql://kit:kit@localhost:5432/kit"

# --- Auth (REQUIRED) ----------------------------------------
# Generate with: openssl rand -base64 32  (or `npx auth secret`)
AUTH_SECRET=""
# Canonical app URL; http://localhost:3000 in dev.
AUTH_URL="http://localhost:3000"

# --- Auth providers (OPTIONAL — buttons hide if unset) ------
# Google: https://console.cloud.google.com/apis/credentials
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""
# GitHub: https://github.com/settings/developers
AUTH_GITHUB_ID=""
AUTH_GITHUB_SECRET=""

# --- Email / Resend (OPTIONAL in dev) -----------------------
# https://resend.com/api-keys — without it, magic links and emails
# log to the console (dev transport).
RESEND_API_KEY=""
EMAIL_FROM="AI Kit <noreply@example.com>"
